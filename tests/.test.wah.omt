# Framework for running automated tests on Open Source Brain
# See https://github.com/OpenSourceBrain/osb-model-validation for more details
 
target: tests/test_worm_alone_half.py
engine: Brian2  # This installs Brian2, but all we really need is a Python environment to run the script in
mep: .test.wah.mep
experiments:
  Test:
    observables:
      spike times:
        file: 
          path: ../simulations/test_worm_alone_half/muscles_activity_buffer.txt
          columns: [0, 1]
          scaling: [1, 1]
        spike detection: 
          method: threshold
          threshold: 0.1
        tolerance: 0